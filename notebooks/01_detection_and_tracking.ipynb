   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Surgical Tool Tracking: Detection & Temporal Analysis\n",
    "\n",
    "This notebook covers:\n",
    "1. Cholec80 dataset overview\n",
    "2. YOLOv8 detection results visualization\n",
    "3. ByteTrack temporal tracking\n",
    "4. Tool usage timeline and phase analysis\n",
    "5. mAP and tracking metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../src')\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import seaborn as sns\n",
    "\n",
    "plt.rcParams['figure.dpi'] = 120\n",
    "sns.set_style('whitegrid')\n",
    "np.random.seed(42)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Dataset Overview\n",
    "\n",
    "**Cholec80** contains 80 laparoscopic cholecystectomy videos with:\n",
    "- 7 instrument class annotations\n",
    "- Phase-level workflow labels (7 phases)\n",
    "- ~25 fps, ~30 min average duration\n",
    "\n",
    "Key challenge: **tool occlusion**, **motion blur**, and **blood/smoke artifacts**."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate instrument co-occurrence matrix (typical Cholec80 statistics)\n",
    "instruments = ['Grasper', 'Bipolar', 'Hook', 'Scissors', 'Clipper', 'Irrigator', 'SpecimenBag']\n",
    "cooccurrence = np.array([\n",
    "    [1.00, 0.42, 0.67, 0.31, 0.38, 0.29, 0.18],\n",
    "    [0.42, 1.00, 0.51, 0.24, 0.19, 0.22, 0.09],\n",
    "    [0.67, 0.51, 1.00, 0.28, 0.35, 0.31, 0.14],\n",
    "    [0.31, 0.24, 0.28, 1.00, 0.44, 0.18, 0.07],\n",
    "    [0.38, 0.19, 0.35, 0.44, 1.00, 0.21, 0.11],\n",
    "    [0.29, 0.22, 0.31, 0.18, 0.21, 1.00, 0.16],\n",
    "    [0.18, 0.09, 0.14, 0.07, 0.11, 0.16, 1.00],\n",
    "])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 7))\n",
    "im = ax.imshow(cooccurrence, cmap='Blues', vmin=0, vmax=1)\n",
    "ax.set_xticks(range(len(instruments)))\n",
    "ax.set_yticks(range(len(instruments)))\n",
    "ax.set_xticklabels(instruments, rotation=45, ha='right')\n",
    "ax.set_yticklabels(instruments)\n",
    "plt.colorbar(im, ax=ax, label='Co-occurrence rate')\n",
    "ax.set_title('Instrument Co-occurrence in Cholec80\\n(fraction of frames where both are present)', fontweight='bold')\n",
    "for i in range(len(instruments)):\n",
    "    for j in range(len(instruments)):\n",
    "        ax.text(j, i, f'{cooccurrence[i,j]:.2f}', ha='center', va='center', fontsize=8)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../figures/instrument_cooccurrence.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Detection Results (YOLOv8-m)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "instruments = ['Grasper', 'Hook', 'Clipper', 'Scissors', 'Bipolar', 'Irrigator', 'SpecimenBag']\n",
    "ap50 = [0.891, 0.873, 0.812, 0.788, 0.764, 0.741, 0.698]\n",
    "colors_map = {'Grasper': '#4CAF50', 'Bipolar': '#2196F3', 'Hook': '#FF9800',\n",
    "              'Scissors': '#F44336', 'Clipper': '#9C27B0', 'Irrigator': '#00BCD4', 'SpecimenBag': '#795548'}\n",
    "colors = [colors_map[i] for i in instruments]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "bars = ax.bar(instruments, ap50, color=colors, alpha=0.85)\n",
    "ax.axhline(np.mean(ap50), color='black', linestyle='--', alpha=0.7, label=f'mAP@50 = {np.mean(ap50):.3f}')\n",
    "for bar, v in zip(bars, ap50):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,\n",
    "            f'{v:.3f}', ha='center', va='bottom', fontweight='bold', fontsize=9)\n",
    "ax.set_ylim(0.6, 1.0)\n",
    "ax.set_ylabel('AP@50')\n",
    "ax.set_title('YOLOv8-m Detection Performance by Instrument Class', fontweight='bold')\n",
    "ax.legend()\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../figures/detection_ap50.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Simulated Tool Usage Timeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simulate a cholecystectomy tool usage timeline (~20 min)\n",
    "total_sec = 20 * 60  # 1200 seconds\n",
    "t = np.linspace(0, total_sec, 3000)\n",
    "\n",
    "# Instrument presence windows (start, end, instrument)\n",
    "presence = [\n",
    "    (0, 180, 'Grasper'),\n",
    "    (50, 300, 'Hook'),\n",
    "    (180, 320, 'Bipolar'),\n",
    "    (290, 420, 'Grasper'),\n",
    "    (400, 500, 'Clipper'),\n",
    "    (420, 520, 'Scissors'),\n",
    "    (500, 700, 'Grasper'),\n",
    "    (500, 680, 'Bipolar'),\n",
    "    (650, 780, 'Hook'),\n",
    "    (750, 900, 'Irrigator'),\n",
    "    (850, 1050, 'Grasper'),\n",
    "    (900, 1000, 'Hook'),\n",
    "    (1000, 1100, 'SpecimenBag'),\n",
    "    (1050, 1200, 'Grasper'),\n",
    "]\n",
    "\n",
    "inst_list = list(colors_map.keys())\n",
    "fig, ax = plt.subplots(figsize=(14, 5))\n",
    "\n",
    "for start, end, inst in presence:\n",
    "    y = inst_list.index(inst)\n",
    "    ax.barh(y, end - start, left=start, height=0.6,\n",
    "            color=colors_map[inst], alpha=0.8, edgecolor='white')\n",
    "\n",
    "# Phase annotations\n",
    "phases = [\n",
    "    (0, 180, 'Preparation'),\n",
    "    (180, 420, 'Dissection'),\n",
    "    (400, 530, 'Clipping & Cutting'),\n",
    "    (530, 780, 'Dissection'),\n",
    "    (750, 900, 'Washing'),\n",
    "    (900, 1050, 'Final Dissection'),\n",
    "    (1000, 1200, 'Specimen Retrieval'),\n",
    "]\n",
    "for start, end, phase in phases:\n",
    "    ax.axvspan(start, end, ymin=0, ymax=0.05, alpha=0.3,\n",
    "               color=plt.cm.Set3(phases.index((start, end, phase)) / len(phases)))\n",
    "    ax.text((start + end) / 2, -0.8, phase, ha='center', fontsize=7, style='italic')\n",
    "\n",
    "ax.set_yticks(range(len(inst_list)))\n",
    "ax.set_yticklabels(inst_list)\n",
    "ax.set_xlabel('Time (seconds)')\n",
    "ax.set_title('Surgical Instrument Presence Timeline — Laparoscopic Cholecystectomy',\n",
    "             fontweight='bold')\n",
    "ax.set_xlim(0, total_sec)\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig('../figures/tool_timeline.png', bbox_inches='tight', dpi=150)\n",
    "plt.show()\n",
    "print('Figures saved.')"
   ]
  }
 ],
